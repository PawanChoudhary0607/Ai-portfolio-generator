# Copy to .env and adjust for your environment. Never commit the real .env.

ENVIRONMENT=development
DEBUG=true

# Comma-separated origins are not supported by pydantic-settings' default
# list parsing from env vars — if you need to override CORS_ORIGINS, set
# it as a JSON array string, e.g. CORS_ORIGINS=["http://localhost:5173"]

DATABASE_URL=sqlite:///./data/app.db

JWT_SECRET_KEY=change-me-to-a-long-random-string-before-deploying
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

MAX_UPLOAD_SIZE_BYTES=10485760

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_TIMEOUT_SECONDS=120
